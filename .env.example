# Supabase Configuration
# Get from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Admin Authentication
ADMIN_EMAIL=admin@portfolio.com
ADMIN_PASSWORD=admin123
AUTH_SECRET=change-this-to-random-string

# Database Initialization Secret
INIT_SECRET=your-init-secret

# Public Contact Information (displayed on website)
NEXT_PUBLIC_EMAIL=your-email@example.com
NEXT_PUBLIC_GITHUB=https://github.com/yourusername
NEXT_PUBLIC_LINKEDIN=https://linkedin.com/in/yourusername
NEXT_PUBLIC_LOCATION=Your Location
